{
  "expo": {
    "name": "After Me",
    "slug": "after-me-mobile",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D3142"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.afterme.app",
      "buildNumber": "6",
      "infoPlist": {
        "NSFaceIDUsageDescription": "After Me uses Face ID to securely access your encrypted vault.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.icloud-services": [
          "CloudDocuments"
        ],
        "com.apple.developer.icloud-container-identifiers": [
          "iCloud.com.afterme.app"
        ],
        "com.apple.developer.ubiquity-container-identifiers": [
          "iCloud.com.afterme.app"
        ]
      }
    },
    "android": {
      "package": "com.afterme.app",
      "versionCode": 9,
      "adaptiveIcon": {
        "backgroundColor": "#2D3142",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "com.android.vending.BILLING"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-document-scanner-plugin",
        {
          "cameraPermission": "Allow After Me to access your camera to scan documents."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow After Me to access your photos to import documents.",
          "cameraPermission": "Allow After Me to access your camera to take photos of documents."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "After Me uses Face ID to securely access your encrypted vault."
        }
      ],
      "expo-font",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "30a5546b-67d9-4727-b921-f204bff3b298"
      }
    },
    "owner": "elufadeju"
  }
}
